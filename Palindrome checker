//PALINDROME CHECKER
#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char str[200], clean[200];
    int i, j = 0, len, flag = 1;

    printf("Enter a phrase: ");
    fgets(str, sizeof(str), stdin);

    // Remove spaces and convert to lowercase
    for(i = 0; str[i] != '\0'; i++) {
        if(isalnum(str[i])) {
            clean[j++] = tolower(str[i]);
        }
    }
    clean[j] = '\0';

    len = strlen(clean);

    // Check palindrome
    for(i = 0; i < len/2; i++) {
        if(clean[i] != clean[len - i - 1]) {
            flag = 0;
            break;
        }
    }

    if(flag)
        printf("Palindrome\n");
    else
        printf("Not a Palindrome\n");

    return 0;
}
    
    
    
                
                
                    
                    
        
    
